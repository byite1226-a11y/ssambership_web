{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(npx tsc *)",
      "Bash(npm test*)",
      "Read",
      "Bash(docker exec *)",
      "Bash(xargs grep -l \"community_posts\\\\|shortform_posts\\\\|community_comments\\\\|hide.*post\\\\|delete.*post\")",
      "Bash(npx playwright *)",
      "PowerShell(Get-NetTCPConnection *)",
      "Bash(netstat -ano)"
    ],
    "defaultMode": "acceptEdits"
  }
}
